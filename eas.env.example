# EAS Build environment variables
#
# Do NOT commit real secrets. Copy this list when configuring EAS:
#
#   eas env:create --environment production --name EXPO_PUBLIC_REPLICATE_API_TOKEN --value "..." --visibility secret
#
# Or use the Expo dashboard: Project → Environment variables → production
#
# Required for App Store production builds
# ----------------------------------------
EXPO_PUBLIC_REPLICATE_API_TOKEN=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_SUPABASE_STAGING_BUCKET=homeai-uploads
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
#
# Public URLs (safe to set in eas.json "env" or as plain EAS variables)
EXPO_PUBLIC_LEGAL_PRIVACY_URL=https://homeai-website.vercel.app/#privacy
EXPO_PUBLIC_LEGAL_TERMS_URL=https://homeai-website.vercel.app/#terms
#
# Optional
# EXPO_PUBLIC_REPLICATE_MODEL_VERSION=
# EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=   # Android builds only
# EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_STAGING_MOCK=0
