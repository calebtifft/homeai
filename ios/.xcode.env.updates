# Embed JS (and EXPO_PUBLIC_* from .env) when building from Xcode — Debug or Release.
# Without this, Debug builds skip bundling and expect Metro; staging/env fixes won't ship.
unset SKIP_BUNDLING

# Export .env into the bundle script environment (path may contain spaces).
if [[ -n "${PROJECT_ROOT:-}" && -f "${PROJECT_ROOT}/.env" ]]; then
  set -a
  # shellcheck disable=SC1090
  . "${PROJECT_ROOT}/.env"
  set +a
fi
