# Get a token at https://replicate.com/account/api-tokens
EXPO_PUBLIC_REPLICATE_API_TOKEN=
#
# Network: the device must resolve and reach https://api.replicate.com (HTTPS). If you see
# "Unable to resolve host" / "No address associated with hostname", fix Wi-Fi or cellular
# data, try without VPN, or use a real device instead of an emulator with broken DNS.

# Staging model (copy full "version" string from the model API tab on Replicate).
# Default in code: black-forest-labs/flux-kontext-pro (text + input_image editing).
# EXPO_PUBLIC_REPLICATE_MODEL_VERSION=black-forest-labs/flux-kontext-pro:4e8d527dd58f382067616cd3ce85e6d9ff4d5ce512cc055f2cb78300ad21e27a
# Alternates:
# EXPO_PUBLIC_REPLICATE_MODEL_VERSION=adirik/interior-design:76604baddc85b1b4616e1c6475eca080da339c8875bd4996705440484a6eac38
# EXPO_PUBLIC_REPLICATE_MODEL_VERSION=remodela-ai/virtual_staging_iii:07a6443a8b93083d849e90f22da76fa043c47cdf2377a7170775384a9ba72f61
#
# FLUX Kontext (when version contains flux-kontext):
# EXPO_PUBLIC_FLUX_ASPECT_RATIO=match_input_image
# EXPO_PUBLIC_FLUX_OUTPUT_FORMAT=jpg
# EXPO_PUBLIC_FLUX_SAFETY_TOLERANCE=2
# EXPO_PUBLIC_FLUX_PROMPT_UPSAMPLING=0
# Interior default: lean edit prompt (~300 words). Set 1 only if you need the older long prompt stack.
# EXPO_PUBLIC_FLUX_VERBOSE_PROMPT=0

# adirik — “Mostly empty” on the review step (default empty-room path):
# EXPO_PUBLIC_ADIRIK_NUM_INFERENCE_STEPS=50
# EXPO_PUBLIC_ADIRIK_GUIDANCE_SCALE=15
# EXPO_PUBLIC_ADIRIK_PROMPT_STRENGTH=0.8
# adirik — “Furnished / staged” only (stronger defaults: more steps, guidance, img2img strength):
# EXPO_PUBLIC_ADIRIK_FURNISHED_NUM_INFERENCE_STEPS=55
# EXPO_PUBLIC_ADIRIK_FURNISHED_GUIDANCE_SCALE=16
# EXPO_PUBLIC_ADIRIK_FURNISHED_PROMPT_STRENGTH=0.9
# remodela — “Furnished / staged” only (if you use that model):
# EXPO_PUBLIC_REMODELA_FURNISHED_NUM_INFERENCE_STEPS=55
# EXPO_PUBLIC_REMODELA_FURNISHED_CONDITION_SCALE=0.82

# Optional — Google Gemini: short phrase to enrich prompts (wording adapts for FLUX vs diffusion models).
# EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash
# EXPO_PUBLIC_GEMINI_PROMPT_AUGMENT=0
# EXPO_PUBLIC_GEMINI_USE_VISION=1

# Optional integer seed for reproducible output:
# EXPO_PUBLIC_REPLICATE_SEED=42

# Set to 1 only for a fake demo image (same stock photo every time; ignores your room).
# Leave unset or 0 when using a real token above.
# EXPO_PUBLIC_STAGING_MOCK=1
#
# Local dev only — skip 3/day free cap (do not set on EAS production):
# EXPO_PUBLIC_STAGING_UNLIMITED=1

# Supabase (optional): after staging, original + result images upload to Storage.
# Best practice: keep the bucket private; app uses signed URLs and user-scoped paths:
# users/<auth.uid()>/sessions/<session-id>/original.jpg + staged.jpg
# Project Settings → API: copy Project URL. Under API Keys use the publishable key
# (sb_publishable_…) — NOT the secret key (sb_secret_…), never put secret in the app.
# EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy tab "anon" JWT still works if you prefer:
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Bucket name (create in Dashboard → Storage; keep PRIVATE; see supabase/storage-policies.sql).
# Default in SQL script: homeai-uploads
# EXPO_PUBLIC_SUPABASE_STAGING_BUCKET=homeai-uploads
#
# Device-only auth: Dashboard → Authentication → Providers → enable "Anonymous sign-in".
# The app calls signInAnonymously() on launch; no email/OAuth redirect URLs are required.
#
# RevenueCat (iOS / Android subscriptions):
# Local dev (Test Store): one test_… key from Dashboard → Apps & providers → Test Store.
#   EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=test_...
#   EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=test_...   # same test_ key is OK for both in dev
# Production: platform keys only — appl_… (iOS), goog_… (Android). Never ship test_ keys.
# Dashboard must list package com.homeai.aihomedesign (Android) and com.homeai.aihomedesign (iOS).
# Error 7117 / "network configuration issue" → wrong key, missing Test Store/Offering, or bad App User ID (no "/" or "user:" prefixes).
# EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
# Optional: verbose RevenueCat SDK logs (otherwise WARN in dev).
# EXPO_PUBLIC_REVENUECAT_DEBUG=1
#
# Legal document URLs (override if you host policies on a different domain):
# EXPO_PUBLIC_LEGAL_PRIVACY_URL=https://homeai-website.vercel.app/#privacy
# EXPO_PUBLIC_LEGAL_TERMS_URL=https://homeai-website.vercel.app/#terms
#
# EAS production builds: set secrets via `eas env:create` — see eas.env.example
