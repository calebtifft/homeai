{
  "expo": {
    "name": "HomeAI",
    "slug": "homeai",
    "scheme": "homeai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1419"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "HomeAI needs camera access to take room photos for staging.",
        "NSPhotoLibraryUsageDescription": "HomeAI needs access to your photos to stage your room images.",
        "NSPhotoLibraryAddUsageDescription": "HomeAI saves your staged room image to your photo library when you tap Save to Photos.",
        "ITSAppUsesNonExemptEncryption": false,
        "UTImportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "public.avif",
            "UTTypeDescription": "AVIF Image",
            "UTTypeConformsTo": ["public.image"],
            "UTTypeTagSpecification": {
              "public.filename-extension": ["avif"],
              "public.mime-type": ["image/avif"]
            }
          },
          {
            "UTTypeIdentifier": "public.heic",
            "UTTypeDescription": "HEIC Image",
            "UTTypeConformsTo": ["public.image"],
            "UTTypeTagSpecification": {
              "public.filename-extension": ["heic"],
              "public.mime-type": ["image/heic"]
            }
          },
          {
            "UTTypeIdentifier": "public.heif",
            "UTTypeDescription": "HEIF Image",
            "UTTypeConformsTo": ["public.image"],
            "UTTypeTagSpecification": {
              "public.filename-extension": ["heif"],
              "public.mime-type": ["image/heif"]
            }
          },
          {
            "UTTypeIdentifier": "public.tiff",
            "UTTypeDescription": "TIFF Image",
            "UTTypeConformsTo": ["public.image"],
            "UTTypeTagSpecification": {
              "public.filename-extension": ["tif", "tiff"],
              "public.mime-type": ["image/tiff"]
            }
          },
          {
            "UTTypeIdentifier": "com.compuserve.gif",
            "UTTypeDescription": "GIF Image",
            "UTTypeConformsTo": ["public.image"],
            "UTTypeTagSpecification": {
              "public.filename-extension": ["gif"],
              "public.mime-type": ["image/gif"]
            }
          }
        ]
      },
      "bundleIdentifier": "com.ov.homeai"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1419"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "package": "com.ov.homeai"
    },
    "plugins": [
      "./plugins/withIosXcodeSpacesPathFix.js",
      [
        "expo-image-picker",
        {
          "photosPermission": "HomeAI needs access to your photos to stage your room images.",
          "cameraPermission": "HomeAI needs camera access to take room photos for staging.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "HomeAI needs access to your photos to stage your room images.",
          "savePhotosPermission": "Allow HomeAI to save staged images to your gallery.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0f1419",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "37dedcb9-f251-4896-88ba-3c9ef9092540"
      }
    },
    "owner": "markthomass-organization"
  }
}
